#!/bin/bash
set -euxo pipefail

# ─── Java 17 ──────────────────────────────────────────────────────────────────
apt-get update && apt-get install -y --no-install-recommends \
    wget curl git vim nano unzip ca-certificates bash-completion \
    fontconfig

# Eclipse Temurin 17
wget -qO - https://packages.adoptium.net/artifactory/api/gpg/key/public \
    | gpg --dearmor > /etc/apt/trusted.gpg.d/adoptium.gpg
echo "deb https://packages.adoptium.net/artifactory/deb $(awk -F= '/^VERSION_CODENAME/{print $2}' /etc/os-release) main" \
    > /etc/apt/sources.list.d/adoptium.list
apt-get update && apt-get install -y temurin-17-jdk

java -version

# ─── Maven 3.9 ────────────────────────────────────────────────────────────────
MAVEN_VERSION=3.9.9
wget -q "https://archive.apache.org/dist/maven/maven-3/${MAVEN_VERSION}/binaries/apache-maven-${MAVEN_VERSION}-bin.tar.gz" \
    -O /tmp/maven.tar.gz
tar -xzf /tmp/maven.tar.gz -C /opt
ln -s /opt/apache-maven-${MAVEN_VERSION} /opt/maven
ln -s /opt/maven/bin/mvn /usr/local/bin/mvn
rm /tmp/maven.tar.gz

export MAVEN_HOME=/opt/maven
echo "export MAVEN_HOME=/opt/maven" >> /root/.bashrc
echo 'export PATH="${MAVEN_HOME}/bin:${PATH}"' >> /root/.bashrc

mvn -version

# ─── Temporal CLI ─────────────────────────────────────────────────────────────
curl -sSf https://temporal.download/cli.sh | sh
chmod +x /root/.temporalio/bin/temporal
ln -sf /root/.temporalio/bin/temporal /usr/local/bin/temporal
export PATH=$PATH:/root/.temporalio/bin:/usr/local/bin
echo 'export PATH=$PATH:/root/.temporalio/bin:/usr/local/bin' >> /root/.bashrc

temporal --version

# ─── Temporal server (systemd service) ────────────────────────────────────────
mkdir -p /workspace

cat > /etc/systemd/system/temporal-server.service <<'EOF'
[Unit]
Description=Temporal Dev Server
After=network.target

[Service]
Type=simple
User=root
ExecStart=/usr/local/bin/temporal server start-dev \
    --ui-port 8080 \
    --ip 0.0.0.0 \
    --db-filename /workspace/temporal.db
Restart=on-failure
RestartSec=5
StandardOutput=append:/workspace/temporal.log
StandardError=append:/workspace/temporal.log

[Install]
WantedBy=multi-user.target
EOF

systemctl enable temporal-server
systemctl start temporal-server

# Wait for server to be healthy
echo "Waiting for Temporal server..."
for i in $(seq 1 30); do
    if temporal operator cluster health --address 127.0.0.1:7233 2>/dev/null | grep -q SERVING; then
        echo "Temporal server healthy."
        break
    fi
    sleep 3
done

# ─── code-server (VS Code in browser) ─────────────────────────────────────────
curl -fsSL https://code-server.dev/install.sh | sh

# Install Java extension pack — do this before writing settings so the install
# process doesn't clobber our settings.json
code-server --install-extension vscjava.vscode-java-pack

# User settings — written after extension install to avoid being overwritten
mkdir -p /root/.local/share/code-server/User
cat > /root/.local/share/code-server/User/settings.json <<'EOF'
{
    "workbench.colorTheme": "Default Dark+",
    "workbench.startupEditor": "none",
    "security.workspace.trust.enabled": false,
    "editor.fontSize": 14,
    "editor.tabSize": 4,
    "java.format.enabled": true,
    "workbench.activityBar.visible": false,
    "workbench.secondarySideBar.visible": false,
    "workbench.statusBar.visible": true,
    "editor.suggestOnTriggerCharacters": true,
    "editor.quickSuggestions": {
        "other": true,
        "comments": false,
        "strings": false
    }
}
EOF

# Workspace settings — these override user settings and survive extension updates
# Written to /workspace/.vscode/ so they apply whenever /workspace/exercise is opened.
# Per-challenge setup scripts will also write to /workspace/exercise/.vscode/.
mkdir -p /workspace/.vscode
cat > /workspace/.vscode/settings.json <<'EOF'
{
    "workbench.activityBar.visible": false,
    "workbench.secondarySideBar.visible": false,
    "editor.suggestOnTriggerCharacters": true,
    "editor.quickSuggestions": {
        "other": true,
        "comments": false,
        "strings": false
    },
    "java.project.referencedLibraries": []
}
EOF

cat > /etc/systemd/system/code-server.service <<'EOF'
[Unit]
Description=Code Server
After=network.target

[Service]
Type=simple
Restart=always
RestartSec=1
User=root
ExecStart=/usr/bin/code-server --host 0.0.0.0 --port 8443 --cert --auth none /workspace/exercise

[Install]
WantedBy=multi-user.target
EOF

systemctl enable code-server
systemctl start code-server

# ─── Pull exercise code from our sandbox image ────────────────────────────────
# The exercises are baked into ghcr.io/mmerrell/temporal-java-sandbox — we
# extract them using a throwaway container rather than re-cloning or re-building.
docker pull ghcr.io/mmerrell/temporal-java-sandbox:latest
docker create --name tmp-sandbox ghcr.io/mmerrell/temporal-java-sandbox:latest
docker cp tmp-sandbox:/opt/exercises /workspace/exercises
docker rm tmp-sandbox

# ─── Pre-warm Maven dependency cache ─────────────────────────────────────────
# All 8 pom files so every challenge starts with a warm cache
for dir in \
    /workspace/exercises/1_converting/practice \
    /workspace/exercises/1_converting/solution \
    /workspace/exercises/2_child_workflows/practice \
    /workspace/exercises/2_child_workflows/solution \
    /workspace/exercises/3_parallel_activities/practice \
    /workspace/exercises/3_parallel_activities/solution \
    /workspace/exercises/4_cost_optimization/practice \
    /workspace/exercises/4_cost_optimization/solution; do
    echo "Warming Maven cache for $dir..."
    mvn -f "$dir/pom.xml" dependency:resolve -q
done

# ─── Shell environment ────────────────────────────────────────────────────────
cat >> /root/.bashrc <<'EOF'

export TEMPORAL_ADDRESS="127.0.0.1:7233"
alias tl="temporal workflow list"
alias mvnw="mvn compile exec:java"
EOF

# ─── Helper: write a .code-workspace that pre-opens files ───────────────────
# Per-challenge setup scripts call this to stage files for VS Code to open.
# VS Code restores open editors from the workspace file on next load.
# Usage: /usr/local/bin/stage-vscode-files file1 file2 ...
cat > /usr/local/bin/stage-vscode-files <<'SCRIPT'
#!/bin/bash
FILES=("$@")

# Build the openEditors JSON array
EDITORS=""
for f in "${FILES[@]}"; do
    EDITORS+="        {\"uri\": \"file://${f}\"},\n"
done
# Remove trailing comma+newline and trim
EDITORS=$(echo -e "$EDITORS" | sed '$ s/,$//')

mkdir -p /workspace/exercise/.vscode

# Write a tasks.json that VS Code reads on open — this is a no-op task
# but forces VS Code to notice the workspace and restore editors from
# the untitled session stored below.
cat > /workspace/exercise/.vscode/tasks.json <<EOF
{
    "version": "2.0.0",
    "tasks": []
}
EOF

# Write a launch config — empty but causes Java extension to activate early
cat > /workspace/exercise/.vscode/launch.json <<EOF
{
    "version": "0.2.0",
    "configurations": []
}
EOF

# Pre-populate code-server's workspace storage with open editors.
# code-server stores this in a predictable path based on workspace folder hash.
# The simplest reliable approach: write the files into a .code-workspace file
# and point code-server at it instead of the raw folder.
FIRST="${FILES[0]}"
LAST="${FILES[-1]}"

cat > /workspace/exercise.code-workspace <<EOF
{
    "folders": [
        { "path": "/workspace/exercise" }
    ],
    "settings": {
        "workbench.activityBar.visible": false,
        "workbench.secondarySideBar.visible": false,
        "editor.suggestOnTriggerCharacters": true,
        "editor.quickSuggestions": {
            "other": true,
            "comments": false,
            "strings": false
        }
    }
}
EOF
SCRIPT
chmod +x /usr/local/bin/stage-vscode-files

# Update code-server to open the workspace file instead of the raw folder
# This is done by updating the systemd ExecStart to point at the .code-workspace
# The per-challenge setup scripts will create exercise.code-workspace before
# code-server restarts, so it will pick up the right files.
cat > /etc/systemd/system/code-server.service <<'EOF'
[Unit]
Description=Code Server
After=network.target

[Service]
Type=simple
Restart=always
RestartSec=1
User=root
ExecStart=/usr/bin/code-server --host 0.0.0.0 --port 8443 --cert --auth none /workspace/exercise.code-workspace

[Install]
WantedBy=multi-user.target
EOF
systemctl daemon-reload
systemctl restart code-server

echo "Track setup complete."
