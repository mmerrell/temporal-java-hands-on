#!/bin/bash
# check-shell for Exercise 4: Cost Optimization with Local Activities
#
# Key things to verify in FulfillmentWorkflowImpl.java:
#   1. LocalActivityOptions used (not ActivityOptions for the local stub)
#   2. Workflow.newLocalActivityStub() used (not newActivityStub)
#   3. localActivities field no longer null
#   4. localActivities.validateOrder() called
#   5. localActivities.fraudCheck() called
#   6. Both local calls appear BEFORE the child workflow stub creation
#      (ordering check via line numbers using grep -n)
#   7. Project compiles

EXERCISE_DIR="/workspace/exercise"
WORKFLOW_IMPL="$EXERCISE_DIR/src/main/java/fulfillment/FulfillmentWorkflowImpl.java"

fail() { echo "FAIL: $1"; exit 1; }
pass() { echo "PASS: $1"; }

# ─── Check 1: LocalActivityOptions used ──────────────────────────────────────
if ! grep -q "LocalActivityOptions" "$WORKFLOW_IMPL"; then
  fail "FulfillmentWorkflowImpl is missing LocalActivityOptions. Use LocalActivityOptions.newBuilder() — not ActivityOptions — for the local activity stub."
fi
pass "LocalActivityOptions used"

# ─── Check 2: newLocalActivityStub used ──────────────────────────────────────
if ! grep -q "newLocalActivityStub" "$WORKFLOW_IMPL"; then
  fail "FulfillmentWorkflowImpl is missing Workflow.newLocalActivityStub(). Use newLocalActivityStub, not newActivityStub, for the LocalFulfillmentActivities stub."
fi
pass "Workflow.newLocalActivityStub() used"

# ─── Check 3: localActivities field no longer null ───────────────────────────
if grep -q "localActivities = null" "$WORKFLOW_IMPL"; then
  fail "The localActivities field is still null. Replace it with a real Workflow.newLocalActivityStub() call."
fi
pass "localActivities stub initialized"

# ─── Check 4: validateOrder called ───────────────────────────────────────────
if ! grep -q "localActivities\.validateOrder" "$WORKFLOW_IMPL"; then
  fail "FulfillmentWorkflowImpl is missing localActivities.validateOrder(order). Add it before the child workflow invocation."
fi
pass "localActivities.validateOrder() called"

# ─── Check 5: fraudCheck called ──────────────────────────────────────────────
if ! grep -q "localActivities\.fraudCheck" "$WORKFLOW_IMPL"; then
  fail "FulfillmentWorkflowImpl is missing localActivities.fraudCheck(order). Add it before the child workflow invocation."
fi
pass "localActivities.fraudCheck() called"

# ─── Check 6: Local activity calls appear BEFORE child workflow stub ──────────
# We extract line numbers for validateOrder and newChildWorkflowStub, then compare.
validate_line=$(grep -n "localActivities\.validateOrder" "$WORKFLOW_IMPL" | head -1 | cut -d: -f1)
child_stub_line=$(grep -n "newChildWorkflowStub" "$WORKFLOW_IMPL" | head -1 | cut -d: -f1)

if [[ -z "$validate_line" || -z "$child_stub_line" ]]; then
  fail "Could not verify ordering of local activity calls vs. child workflow stub. Ensure both are present."
fi

if [[ "$validate_line" -ge "$child_stub_line" ]]; then
  fail "localActivities.validateOrder() must be called BEFORE the child workflow stub. Move the local activity calls to the top of processOrder()."
fi
pass "Local activity calls ordered before child workflow"

# ─── Check 7: Compile ────────────────────────────────────────────────────────
echo "Running mvn compile..."
cd "$EXERCISE_DIR"
if ! mvn compile -q 2>&1; then
  fail "Project does not compile. Fix compilation errors above and try again."
fi
pass "Project compiles successfully"

echo ""
echo "✅ All checks passed!"
echo "   Terminal 1: mvn compile exec:java -Dexec.mainClass=\"fulfillment.FulfillmentWorker\""
echo "   Terminal 2: mvn exec:java -Dexec.mainClass=\"fulfillment.Starter\""
echo "   Open fulfillment-ORD-1004 in the Web UI and look for MarkerRecorded events"
echo "   (validateOrder + fraudCheck) vs. the ActivityTask triplets (processPayment, dispatch)."
