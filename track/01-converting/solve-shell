#!/bin/bash
# solve-shell for Exercise 1: Converting a Workflow
# Copies solution source over the practice source, then recompiles.

EXERCISE_DIR="/home/user/exercise"
SOLUTION_DIR="/home/user/solution"

echo "Applying solution for Exercise 1..."

cp -r "$SOLUTION_DIR/src/." "$EXERCISE_DIR/src/"

cd "$EXERCISE_DIR"
mvn compile -q

echo ""
echo "✅ Solution applied."
echo "   Review the changes:"
echo "     - src/main/java/fulfillment/FulfillmentActivitiesImpl.java"
echo "     - src/main/java/fulfillment/FulfillmentWorkflowImpl.java"
echo ""
echo "   Run the worker and starter to see durable execution in action:"
echo "   Terminal 1: mvn compile exec:java -Dexec.mainClass=\"fulfillment.FulfillmentWorker\""
echo "   Terminal 2: mvn exec:java -Dexec.mainClass=\"fulfillment.Starter\""
